# LLM API 配置（任意 OpenAI 兼容服务：DeepSeek / 智谱 GLM / OpenAI 等）
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-3.5-turbo

# ── 向量检索阈值（不填则用 config.py 里的默认值，填了会覆盖默认值）──
# VECTOR_MIN_DISTANCE_THRESHOLD：L2 距离上限，默认 12.0。
#   覆盖效果：最近的向量结果距离超过此值，视为"完全不相关"，整批丢弃。
#   调大=更宽松（更容易命中知识），调小=更严格（更容易判定无关）。
VECTOR_MIN_DISTANCE_THRESHOLD=12.0
# VECTOR_DISTANCE_DELTA：相关性增量，默认 4.0。
#   覆盖效果：在已判定相关的前提下，只保留距离不超过「最小距离 + 此增量」的结果。
#   调大=保留更多条相关 chunk，调小=只保留最贴近的几条。
VECTOR_DISTANCE_DELTA=4.0
